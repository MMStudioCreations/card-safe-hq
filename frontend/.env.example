# Card Safe HQ — Frontend Environment Variables

# ── API ───────────────────────────────────────────────────────────────────────
VITE_API_URL=https://cardsafehq-api.michaelamarino16.workers.dev

# ── Ads (Revenue Infrastructure) ─────────────────────────────────────────────
# Set to "true" to activate ad rendering. Leave as "false" until ready to ship.
VITE_ADS_ENABLED=false

# Your Google AdSense publisher ID (format: ca-pub-XXXXXXXXXXXXXXXX)
# Get this from https://adsense.google.com/start/
VITE_ADSENSE_CLIENT=

# ── Feature Flags ─────────────────────────────────────────────────────────────
VITE_FEATURE_DECK_BUILDER=true
VITE_FEATURE_TRADES=true
VITE_FEATURE_WISHLIST=true
